# Copy this file to .env.local and fill your keys.

# LLM provider keys
GEMINI_API_KEY=
OPENAI_API_KEY=

# Optional model/runtime defaults
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TEMPERATURE=0.0
GEMINI_TIMEOUT_S=60
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.0
OPENAI_TIMEOUT_S=60

# LLM-only blueprint MATPOWER defaults
MATPOWER_DATA_ROOT=data/matpower
MATPOWER_CASE_DATE=2017-01-01
LLM_ONLY_DEBUG_MODE=false
